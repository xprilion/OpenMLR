{
  "name": "open-mlr",
  "version": "1.0.0",
  "type": "module",
  "description": "Open-MLR — AI assistant for ML engineering",
  "scripts": {
    "dev": "concurrently \"bun run dev:server\" \"bun run dev:frontend\"",
    "dev:server": "bun run src/server.ts",
    "dev:frontend": "cd frontend && bun run dev",
    "build": "cd frontend && bun run build",
    "start": "bun run src/server.ts",
    "install:all": "bun install && cd frontend && bun install"
  },
  "dependencies": {
    "ai": "^6.0.168",
    "@ai-sdk/anthropic": "^3.0.71",
    "dotenv": "^17.4.2",
    "openai": "^4.0.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "concurrently": "^9.0.0",
    "typescript": "^5.6.0"
  }
}
