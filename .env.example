# ─── Database (required) ──────────────────────────────────
DATABASE_URL="postgresql://user:pass@localhost:5432/openmlr"

# ─── LLM Providers (at least one required) ────────────────
# Cloud providers
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
OPENROUTER_API_KEY=

# OpenCode Go ($5-10/mo subscription for open models)
# Get API key at https://opencode.ai/auth
# Models: glm-5.1, kimi-k2.6, deepseek-v4-pro, qwen3.6-plus, etc.
# OPENCODE_GO_API_KEY=

# ─── Local Models (OpenAI-compatible APIs) ────────────────
# For Ollama (default: http://localhost:11434/v1)
# OLLAMA_API_BASE=http://localhost:11434/v1
# OLLAMA_MODEL=llama3.1

# For LM Studio (default: http://localhost:1234/v1)
# LMSTUDIO_API_BASE=http://localhost:1234/v1
# LMSTUDIO_MODEL=default

# For any OpenAI-compatible API (vLLM, text-generation-inference, etc.)
# LOCAL_API_BASE=http://localhost:8000/v1
# LOCAL_MODEL=local/my-model
# LOCAL_API_KEY=not-needed

# ─── Background Jobs (optional) ───────────────────────────
# Enable for persistent task tracking and browser-independent processing
# REDIS_URL=redis://localhost:6379/0
# USE_BACKGROUND_JOBS=true
# USE_REDIS_PUBSUB=true

# ─── Search & Research (optional) ─────────────────────────
BRAVE_API_KEY=
SEMANTIC_SCHOLAR_API_KEY=

# ─── GitHub (optional) ────────────────────────────────────
GITHUB_TOKEN=

# ─── Auth ─────────────────────────────────────────────────
JWT_SECRET_KEY=change-me-in-production

# ─── Modal Sandbox (optional) ─────────────────────────────
MODAL_TOKEN_ID=
MODAL_TOKEN_SECRET=
