# OpenMLR Environment Configuration
# Copy to .env and fill in required values
#
# Required variables are marked with (REQUIRED)
# Optional variables have sensible defaults

# ═══════════════════════════════════════════════════════════
# SECURITY (REQUIRED)
# ═══════════════════════════════════════════════════════════

# JWT secret for authentication tokens (REQUIRED)
# Generate with: openssl rand -hex 32
JWT_SECRET=

# CORS allowed origins (comma-separated)
# Default: http://localhost:3000,http://localhost:5173
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ═══════════════════════════════════════════════════════════
# DATABASE
# ═══════════════════════════════════════════════════════════

# PostgreSQL connection (for docker-compose, these are auto-configured)
# POSTGRES_USER=openmlr
# POSTGRES_PASSWORD=openmlr
# POSTGRES_DB=openmlr

# Full database URL (overrides individual vars above)
# DATABASE_URL=postgresql+asyncpg://openmlr:openmlr@localhost:5432/openmlr

# ═══════════════════════════════════════════════════════════
# LLM PROVIDERS (at least one required)
# ═══════════════════════════════════════════════════════════

# Cloud providers
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
OPENROUTER_API_KEY=

# OpenCode Go ($5-10/mo subscription for open models)
# Get API key at https://opencode.ai/auth
# Models: glm-5.1, kimi-k2.6, deepseek-v4-pro, qwen3.6-plus, etc.
# OPENCODE_GO_API_KEY=

# ─── Local Models (OpenAI-compatible APIs) ────────────────
# For Ollama (default: http://localhost:11434/v1)
# OLLAMA_API_BASE=http://localhost:11434/v1
# OLLAMA_MODEL=llama3.1

# For LM Studio (default: http://localhost:1234/v1)
# LMSTUDIO_API_BASE=http://localhost:1234/v1
# LMSTUDIO_MODEL=default

# For any OpenAI-compatible API (vLLM, text-generation-inference, etc.)
# LOCAL_API_BASE=http://localhost:8000/v1
# LOCAL_MODEL=local/my-model
# LOCAL_API_KEY=not-needed

# ═══════════════════════════════════════════════════════════
# BACKGROUND JOBS (optional but recommended for production)
# ═══════════════════════════════════════════════════════════

# Redis connection (auto-configured in docker-compose)
# REDIS_URL=redis://localhost:6379/0

# Enable background job processing
# USE_BACKGROUND_JOBS=true
# USE_REDIS_PUBSUB=true

# ═══════════════════════════════════════════════════════════
# SEARCH & RESEARCH (optional)
# ═══════════════════════════════════════════════════════════

BRAVE_API_KEY=
SEMANTIC_SCHOLAR_API_KEY=

# ═══════════════════════════════════════════════════════════
# GITHUB INTEGRATION (optional)
# ═══════════════════════════════════════════════════════════

GITHUB_TOKEN=

# ═══════════════════════════════════════════════════════════
# MODAL SANDBOX (optional - for cloud code execution)
# ═══════════════════════════════════════════════════════════

MODAL_TOKEN_ID=
MODAL_TOKEN_SECRET=

# ═══════════════════════════════════════════════════════════
# DOCKER SANDBOX SETTINGS
# ═══════════════════════════════════════════════════════════

# Docker image for sandbox execution
# OPEN_MLR_DOCKER_IMAGE=python:3.12-slim

# Allow direct host execution when Docker is unavailable (SECURITY RISK)
# Default: false (commands fail if Docker unavailable)
# OPENMLR_ALLOW_DIRECT_EXEC=false

# Restrict file operations to this directory
# Default: current working directory
# OPENMLR_WORKSPACE_ROOT=/path/to/workspace
