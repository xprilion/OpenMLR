# ─── Database (required) ──────────────────────────────────
DATABASE_URL="postgresql://user:pass@localhost:5432/openmlr"

# ─── LLM Providers (at least one required) ────────────────
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
OPENROUTER_API_KEY=

# ─── Search & Research (optional) ─────────────────────────
BRAVE_API_KEY=
SEMANTIC_SCHOLAR_API_KEY=

# ─── GitHub (optional) ────────────────────────────────────
GITHUB_TOKEN=

# ─── Auth ─────────────────────────────────────────────────
JWT_SECRET_KEY=change-me-in-production

# ─── Modal Sandbox (optional) ─────────────────────────────
MODAL_TOKEN_ID=
MODAL_TOKEN_SECRET=
